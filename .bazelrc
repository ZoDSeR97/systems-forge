# .bazelrc

## Global settings (applies to all commands)

common --announce_rc              # show which rc files are loaded (debugging)
common --show_timestamps          # timestamp each log line

## Build performance & resource control

build --jobs=auto
build --local_cpu_resources=HOST_CPUS
build --local_ram_resources=HOST_RAM * 0.8

## Disk cache for faster incremental builds

build --disk_cache=~/.bazel-cache

## Keep sandbox directories when a build fails (debugging)

build --sandbox_debug

## Output & failure reporting

build --verbose_failures          # show full command line on failure
build --show_result=50            # show up to 50 outputs (reduced from 100)

## Compilation modes

build:dbg --compilation_mode=dbg
build:fastbuild --compilation_mode=fastbuild
build:opt --compilation_mode=opt

### Rust optimization: only enable CPU‑native code when explicitly asked

build:opt --@rules_rust//:rustc_flags=["-Copt-level=3"]

## Zig toolchain (C/C++ compiler)

build --action_env=ZIG_GLOBAL_CACHE_DIR=.zig-cache

## Testing

test --test_output=errors
test --test_summary=detailed
test --test_timeout=60,300,900,3600

## Cross‑compilation (example platforms – define them in //toolchains/BUILD)

build:linux_arm64 --platforms=//toolchains:linux_arm64
build:linux_amd64 --platforms=//toolchains:linux_amd64
build:windows_amd64 --platforms=//toolchains:windows_amd64

## Debugging config (extra verbose, keeps everything)

build:debug --verbose_failures
build:debug --sandbox_debug
build:debug --show_result=100
